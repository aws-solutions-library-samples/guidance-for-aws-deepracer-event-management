{"source":"user-event","type":"click","text":"// Generate 53x11 grid with some text pixels lit\n          // \"P1 DAVE 12.34s\" approximation in row data\n          const rows = 11, cols = 53;\n          const lit = new Set();\n          // Accent bar top\n          for(let c=0;c<53;c++) lit.add(`0,${c}`);\n          // P glyph col 1-4, row 2-8\n          [2,3,4,5,6,7,8].forEach(r=>{lit.add(`${r},1`);});\n          [2,3].forEach(r=>{lit.add(`${r},2`);lit.add(`${r},3`);lit.add(`${r},4`);});\n          lit.add('5,2');lit.add('5,3');lit.add('5,4');\n          // 1 glyph col 6-7\n          [2,3,4,5,6,7,8].forEach(r=>lit.add(`${r},6`));\n          // separator\n          // D glyph col 9-13\n          [2,3,4,5,6,7,8].forEach(r=>lit.add(`${r},9`));\n          lit.add('2,10');lit.add('2,11');lit.add('3,12');lit.add('4,12');lit.add('5,12');lit.add('6,11');lit.add('7,10');lit.add('8,10');\n          // Time \"12.34\" col 20-40\n          [3,4,5,6,7].forEach(r=>{lit.add(`${r},20`);lit.add(`${r},21`);lit.add(`${r},27`);lit.add(`${r},28`);});\n          lit.add('2,22');lit.add('8,22');lit.add('2,25');lit.add('5,25');lit.add('8,25');\n          // Accent bar bottom\n          for(let c=0;c<53;c++) lit.add(`10,${c}`);\n\n          for(let r=0;r<rows;r++){\n            for(let c=0;c<cols;c++){\n              const k=`${r},${c}`;\n              let cls='led';\n              if(r===0||r===10) cls+=' on-r';\n              else if(lit.has(k)) cls+=' on-w';\n              document.write(`<div class=\"${cls}\"></div>`);\n            }\n          }\n        \n      \n      53 × 11 LEDs — landscape strip\n    \n    \n      Galactic Unicorn\n      Wide landscape strip — ideal for scrolling text, leaderboard ticker, and lap time display. Best for mounting along a barrier or desk edge. Limited to ~2 lines of content at once.","choice":"galactic","id":null,"timestamp":1774173357673}
