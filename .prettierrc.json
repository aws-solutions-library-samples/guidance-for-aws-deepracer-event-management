{
  "bracketSpacing": true,
  "endOfLine": "lf",
  "printWidth": 120,
  "semi": true,
  "singleQuote": true,
  "tabWidth": 2,
  "useTabs": false,
  "trailingComma": "es5",
  "overrides": [
    {
      "files": ["website/src/**", "website/leaderboard/src/**", "website/overlays/src/**"],
      "options": {
        "printWidth": 100
      }
    }
  ]
}
